---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"
import { news } from "../data/news";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-3xl font-bold">I'm Yudha Andriano Rismawan</div>
    <div class="text-xl py-3 font-bold">Artificial Intelligence Enthusiast</div>
    <div class="py-2">
      <text class="text-lg">
        A self-motivated and passionate individual pursuing a Master’s degree in Statistics at Institut Teknologi Sepuluh Nopember, working with <a href="https://scholar.google.com/citations?user=0xGypiwAAAAJ&hl=id" target="_blank" class="underline">Prof. Nur Iriawan</a>. I am highly interested in research, particularly in <b> image processing, computer vision, statistical modeling, metaheuristic algorithms, and artificial intelligence </b>. Experienced in medical image research, conference presentations, and writing academic research papers.
      </text>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="https://drive.google.com/file/d/1DhwFi6udD-TxHyVoABzVBjLPQ0XKsGij/view?usp=sharing"
        target="_blank"
        class="btn btn-outline btn-sm rounded-l"
      >
        <i class="fa-solid fa-file-pdf"></i>
        My CV
      </a>

      <a
        href="https://scholar.google.com/citations?user=S04PQ_QAAAAJ&hl=en"
        class="btn btn-sm rounded-l"
      >
        <i class="fa-brands fa-google"></i>
        Google Scholar
      </a>

      <a
        href="https://www.linkedin.com/in/yudha-andriano-rismawan-491020204/"
        target="_blank"
        class="btn btn-sm rounded-l"
      >
        <i class="fa-brands fa-linkedin"></i>
        Let's connect!
      </a>
    </div>
  </div>

  <section class="mt-14">
    <div class="text-3xl font-bold mb-5">News</div>

    {
      news.length > 0 ? (
        <div class="max-h-80 overflow-y-auto border rounded-lg p-4">
          <ul class="space-y-4">
            {news.map((item) => (
              <li class="flex gap-4">
                <span class="font-medium min-w-[100px] whitespace-nowrap">
                  {item.date}
                </span>
                <span set:html={item.title}></span>
              </li>
            ))}
          </ul>
        </div>
      ) : (
        <div class="border rounded-lg p-4 text-gray-500 italic">
          No news available at the moment.
        </div>
      )
    }
  </section>

  <div>
    <div class="text-3xl w-full font-bold mb-2 mt-10">Selected publications</div>
    <div class="text-lg mb-5">Here are some of my selected publications. For more, please check out my <a href="https://scholar.google.com/citations?user=S04PQ_QAAAAJ&hl=en" target="_blank" class="underline">Google Scholar</a>.</div>
  </div>
  <HorizontalCard
    title="Implementation of the Content Based Image Retrieval Method for Classifying Citrus Fruit Diseases"
    img="/cbir.jpg"
    desc="Budi Sunarko, Muhammad Rozy, Apriansyah Wibowo, <b>Yudha Andriano Rismawan</b>"
    url="https://ieeexplore.ieee.org/abstract/document/11413732"
    badge="IEEE"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Implementation of Deep Neural Network Algorithm in Developing Chatbot for Automation of Admission and Integrated Service Helpdesk of Universitas Negeri Semarang"
    img="/chatbot.png"
    desc="Budi Sunarko, Famela Tiara Intan, <b>Yudha Andriano Rismawan</b>, Dhidik Prastiyanto, Arief Arfriandi, Uswatun Hasanah"
    url="https://ieeexplore.ieee.org/abstract/document/10963547"
    badge="IEEE"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Development of coronary heart disease diagnosis system based on facial imagery"
    img="/chd-imagery.jpg"
    desc="<b>Yudha Andriano Rismawan</b>, Agung Adi Firdaus, Indah Novi Yarman, Anisa Dwi Lutfi Yanti, Anan Nugroho, Rachelia Intan Merdina, Andreas Arie Setiawan"
    url="https://doi.org/10.1063/5.0180182"
    badge="AIP Publishing"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
